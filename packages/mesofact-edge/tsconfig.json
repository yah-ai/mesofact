  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["@cloudflare/workers-types", "bun"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "lib": ["ES2022"]
